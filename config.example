# cloud-sync-mover - config.example (B13)
# Copy to config.local (gitignored) and fill in. No secrets here - only paths and switches.
# Override order: CLI flag > ENV (CSM_<SECTION>_<KEY>) > config.local > config.example > code default.

[paths]
# Current (source) location of the synced data folder:
#   OneDrive:      C:\Users\<user>\OneDrive
#   Google Drive:  the Drive mount / virtual drive, e.g. G:\My Drive
source_root =
# Target root to move to (fast, roomy, NON-SMR disk recommended):
#   e.g. D:\OneDrive   or   D:\GoogleDrive
target_root =
# Where the toolkit writes inventory/verification artifacts (local fast disk, NOT the synced folder)
work_dir = C:\cloud-sync-mover-work

[provider]
# onedrive-personal | onedrive-business | google-drive
name = onedrive-personal
# Client version this run was tested against (informational only)
#   e.g. OneDrive 26.108.0607.0002  |  Google Drive for desktop 90.x
client_version =

[google_drive]
# Only used when provider.name = google-drive (ignored for OneDrive).
# Which mode the Google Drive client runs in:
#   streaming = File Stream: online-only placeholders (same RECALL/PINNED attributes as OneDrive FoD)
#   mirror    = local mirror: every file is present locally, there are no placeholders
mode = streaming
# Diagnostics (#5/#8/#15). Read-only paths/markers the diagnose phase samples. Defaults are
# best-effort; tune against your own client's logs. cache_root defaults to %LOCALAPPDATA%\Google\DriveFS.
cache_root =
# WAL size (MB) at/above which the local cache is considered to be doing heavy indexing (a large +
# GROWING WAL during startup is HEALTHY 'initializing', not blocked - #15).
wal_warn_mb = 512
# Stale-upload marker globs (presence = a possibly-stuck upload). ';'-separated, case-insensitive.
stale_marker_patterns = *stale*;*.pending;*.crdownload
# Process name whose CPU is sampled as a liveness signal.
process_name = GoogleDriveFS
# #16: staging-queue dir scanned AT THE ROOT of each mirror root (mount-side upsync-block
# signal; single-level enumeration, content never read, summary redacted to ordinals).
stage_dir_name = .tmp.driveupload
# #16: additional top-level mirror roots on the same sync mount (';'-separated). Include a
# backup root here too if it lives under the sync mount. source_root is always ordinal 0.
extra_mirror_roots =

[diagnose]
# Seconds between the two liveness samples the diagnose phase takes (#15). Larger = more reliable
# progress detection, slower.
sample_seconds = 5
# Preflight (#5) only consults a diagnose result newer than this many minutes; older = stale/ignored
# (transient states like 'initializing' expire).
max_age_minutes = 30

[diagnose_delivery]
# #18 (ADR-014): the diagnose phase ALWAYS writes its local artifact to work_dir. When enabled
# below it ALSO uploads that artifact directly via the provider's REST API - bypassing the
# local sync client, which may be the very thing being diagnosed. Opt-in per A1: default false;
# enabling it is the recorded operator decision that authorizes the (redacted) upload per run.
provider_upload_enabled = false
# google-drive (implemented: Drive files.create, multipart) | onedrive (not yet implemented)
provider = google-drive
# Provider FOLDER ID to upload into (an ID, not a path) - e.g. a dedicated "diagnostics inbox"
# folder; copy the ID from the folder's URL in the provider's web UI.
folder_id =
# Credentials per B13/A2: the NAME of an environment variable holding an OAuth access token
# with file-create scope (Drive: drive.file is sufficient and least-privilege). NEVER put the
# token itself in this file.
credentials_env =
# Write a small local receipt (diagnose_<ts>_delivery.json) with the delivery outcome.
write_receipt = true
# Test seam: override the API base URL (points the upload at a mock). Empty = real endpoint.
endpoint_base =

[probe]
# Round-trip proof the provider is ACTUALLY syncing (#9). All keys optional; the probe is dry-run
# unless run with -Execute. probe_dir must be a dedicated folder INSIDE the synced tree (never the
# live source/target root). The canary written there is a single non-identifying token file.
probe_dir =
# A command (run in YOUR environment) that returns exit 0 once the canary is visible on the OTHER
# side (provider web / a second device). The token is provided via the CSM_PROBE_TOKEN env var and
# an optional {token} placeholder. Example (rclone): rclone lsf remote:probe | findstr %CSM_PROBE_TOKEN%
confirm_command =
# How long to wait for the round-trip, and how often to re-check.
timeout_seconds = 300
poll_seconds = 15

[move]
# FoD / streaming-preserving: never expands the set of locally-materialized files.
# No effect for Google Drive in 'mirror' mode (there are no placeholders to preserve).
preserve_files_on_demand = true
# Minimum days of stable sync before the SOURCE may be moved/removed (deletion gate, A3)
min_stable_days = 5
# All destructive steps are opt-in; dry-run is the default
dry_run_default = true
# Sync-health gate (#1): preflight only PASSES when this is true (or -SyncConfirmed is passed).
# Set to true only after confirming the client shows "Up to date" (no pending changes).
assume_up_to_date = false
# Retire-source stability gate (#2): record when the CLIENT move finished, ISO 8601 UTC
# (e.g. 2026-07-20T10:00:00Z). The gate requires min_stable_days to elapse from this time.
# This value is operator-attested (the toolkit cannot observe the manual client move); set it honestly.
move_completed_utc =
# Retire-source gate (#2): reject preflight/structure/verify artifacts older than this many days.
retire_max_artifact_age_days = 7
# Stage-queue gate (#17): preflight grades NEEDS_CONFIRMATION when a mirror root's staging
# queue is stuck (non-empty + undeletable, see [google_drive] stage_dir_name). Set true ONLY
# as a deliberate, recorded acceptance - the queue is otherwise carried to the destination.
assume_stage_queue_clean = false

[enumeration]
# Junction/reparse safety (#13) is always on: the read phases never traverse THROUGH a junction.
# Provider-internal temp/staging + OS-noise directory names to skip and classify out of the
# user-data baseline (#4). Wildcard, case-insensitive, ';'-separated. Empty = built-in defaults
# (OS noise + Google Drive .tmp.drivedownload/.tmp.driveupload when provider = google-drive).
noise_dir_patterns =
# Preflight (#4) flags a provider staging/noise dir at/above this size (GB) as 'large' - a
# persistently large staging area can signal a stuck upload queue. Investigate before retiring.
staging_warn_gb = 1